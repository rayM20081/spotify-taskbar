<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SpotifyTaskbarPlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid"
          Background="#FF202020"
          Padding="4,2,4,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="2" />
        </Grid.RowDefinitions>

        <!-- Clickable region: album art + title/artist -->
        <Grid Grid.Column="0" Grid.Row="0"
              x:Name="OpenSpotifyArea"
              Background="Transparent"
              Tapped="OnOpenSpotifyTap"
              ToolTipService.ToolTip="Open Spotify">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="32" Height="32" CornerRadius="4"
                    VerticalAlignment="Center"
                    Margin="2,0,6,0"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}">
                <Image x:Name="AlbumArt" Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0">
                <TextBlock x:Name="TitleText" Text="(no track)"
                           FontSize="11" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" MaxLines="1"
                           HorizontalAlignment="Left" />
                <TextBlock x:Name="ArtistText" Text=""
                           FontSize="10" Opacity="0.7"
                           TextTrimming="CharacterEllipsis" MaxLines="1"
                           HorizontalAlignment="Left" />
            </StackPanel>
        </Grid>

        <!-- Transport buttons -->
        <StackPanel Grid.Column="1" Grid.Row="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="0"
                    Margin="0,0,4,0">
            <Button x:Name="PrevButton" Click="OnPrev"
                    Width="28" Height="28" Padding="0"
                    Background="Transparent" BorderBrush="Transparent"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    FontSize="11"
                    Content="&#xE892;"
                    ToolTipService.ToolTip="Previous" />
            <Button x:Name="PlayPauseButton" Click="OnPlayPause"
                    Width="28" Height="28" Padding="0"
                    Background="Transparent" BorderBrush="Transparent"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    FontSize="12"
                    Content="&#xE768;"
                    ToolTipService.ToolTip="Play/Pause" />
            <Button x:Name="NextButton" Click="OnNext"
                    Width="28" Height="28" Padding="0"
                    Background="Transparent" BorderBrush="Transparent"
                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    FontSize="11"
                    Content="&#xE893;"
                    ToolTipService.ToolTip="Next" />
        </StackPanel>

        <!-- Progress (thin, full width, bottom) -->
        <ProgressBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                     x:Name="TimelineBar"
                     Minimum="0" Maximum="1" Value="0"
                     Height="2"
                     Background="Transparent"
                     Margin="0" />
    </Grid>

</Window>
